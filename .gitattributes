# 默认所有文本文件用LF(防止Windows clone后CRLF污染)
* text=auto eol=lf

# Windows专有脚本强制CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.xlsx binary
*.xls binary
*.db binary
*.7z binary
*.zip binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
